<?xml version="1.0"?>
<ruleset name="WordPress Coding Standards">
	<description>BuddyBoss Platform dev PHP_CodeSniffer ruleset.</description>

	<file>src</file>
	<file>bp-loader.php</file>

	<!-- Exclude paths -->
	<exclude-pattern>*/languages/*</exclude-pattern>
	<exclude-pattern>*/lib/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/deprecated/*</exclude-pattern>
	<exclude-pattern>*/bp-integrations/*</exclude-pattern>
	<exclude-pattern>*/bp-core/classes/class-bp-phpmailer.php</exclude-pattern>
	<exclude-pattern>*/bp-core/classes/class-bp-email-tokens.php</exclude-pattern>
	<exclude-pattern>*/js/autocomplete/*</exclude-pattern>
	<exclude-pattern>*/js-templates/*</exclude-pattern>
	<exclude-pattern>awpcp_ad_listing-ajax.php</exclude-pattern>
	<exclude-pattern>*/cli/*</exclude-pattern>

	<!-- Machine-generated PHP-Scoper config — not web-accessible -->
	<exclude-pattern>src/scoper.inc.php</exclude-pattern>

	<!-- webpack-generated asset manifest files — pure data, not web-accessible, no ABSPATH guard needed -->
	<exclude-pattern>*/blocks/*.asset.php</exclude-pattern>

	<!-- Namespaced PHP files (loaded via Composer autoloader, not directly executable — ABSPATH guard breaks namespace declaration) -->
	<exclude-pattern>src/includes/Library/*</exclude-pattern>
	<exclude-pattern>*/bp-performance/classes/class-*.php</exclude-pattern>
	<exclude-pattern>*/bp-core/admin/mothership/*</exclude-pattern>

	<!-- Third-party code -->
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/vendors/*</exclude-pattern>

	<!-- Ensure certain file types aren't sniffed -->
	<exclude-pattern>*\.(css|js)</exclude-pattern>

	<arg name="colors"/>
	<arg value="p"/>

	<ini name="memory_limit" value="1024M"/>

	<!-- Configs -->

	<!-- Loads the PHP Compatibility ruleset. -->
	<rule ref="PHPCompatibilityWP" />

	<!-- PHP version check. -->
	<config name="minimum_supported_wp_version" value="4.7" />
	<config name="testVersion" value="7.4-" />

	<!-- Rules -->
	<rule ref="WordPress">
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_query" />
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared" />
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="buddyboss"/>
			</property>
		</properties>
	</rule>

</ruleset>
